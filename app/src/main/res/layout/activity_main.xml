<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IAGI Android Mobile Development"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btnAppListGridSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="List, Grid and Spinner (Activity 5-1)"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnAppMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Menus and Navigation (Contact &amp; About)"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnRecycleList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="RecyclerView and CardView"
                android:layout_marginBottom="8dp"/>

            <!-- Add more buttons for other activities as needed -->
            <Button
                android:id="@+id/btnAct2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Activity 2"
                android:layout_marginBottom="8dp"/>

             <Button
                android:id="@+id/btnAct3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Activity 3"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnAct5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Activity 5"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnAct7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Activity 7"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnAct8"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Activity 8"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>